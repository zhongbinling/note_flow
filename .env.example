# ===========================================
# NoteFlow Frontend Configuration
# ===========================================
# Copy this file to .env and configure for your environment

# API URL (backend server)
# For development: http://localhost:3001/api
# For production: https://api.yourdomain.com/api
VITE_API_URL=http://localhost:3001/api

# Application URL (for sharing links, email redirects, etc.)
# For development: http://localhost:5177
# For production: https://yourdomain.com
VITE_APP_URL=http://localhost:5177

# Application name
VITE_APP_NAME=NoteFlow
