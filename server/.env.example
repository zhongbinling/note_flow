# ===========================================
# NoteFlow Backend Configuration
# ===========================================
# Copy this file to .env and configure for your environment

# Server Configuration
PORT=3001
NODE_ENV=development
HOST=localhost

# Frontend URL (for CORS and email reset links)
FRONTEND_URL=http://localhost:5177

# Allowed CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://localhost:3000

# ===========================================
# Database Configuration
# ===========================================
# SQLite (for development)
DATABASE_URL="file:./dev.db"

# PostgreSQL (for production)
# DATABASE_URL="postgresql://user:password@localhost:5432/noteflow?schema=public"

# ===========================================
# JWT Configuration
# ===========================================
# IMPORTANT: Change this to a strong random secret in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# Rate Limiting
# ===========================================
# General API rate limit (requests per minute)
RATE_LIMIT_MAX=100
# Auth endpoints rate limit (requests per minute)
AUTH_RATE_LIMIT_MAX=10

# ===========================================
# Email Configuration (SMTP)
# ===========================================
# Required for password reset functionality
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_password
# SMTP_FROM=noreply@noteflow.app

# ===========================================
# Password Reset
# ===========================================
# Token expiry in milliseconds (default: 1 hour)
RESET_TOKEN_EXPIRY=3600000
